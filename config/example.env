# Manifold Markets Trading Bot Configuration
# Rename to .env and fill in your values
# NEVER commit .env to version control

# ============= API Configuration =============
MANIFOLD_API_KEY=your_api_key_here
MANIFOLD_API_URL=https://api.manifold.markets
MANIFOLD_WS_URL=wss://api.manifold.markets

# ============= Environment =============
ENVIRONMENT=development  # development | staging | production
LOG_LEVEL=info           # debug | info | warning | error

# ============= Trading Parameters =============
# Position sizing
MAX_POSITION_SIZE=500          # Max mana per trade
MAX_TOTAL_INVESTED=5000        # Max total invested across all positions
POSITION_SCALE_FACTOR=0.02     # 2% of balance per trade

# Risk management
SLIP_CAP=0.02                  # 2% maximum slip
MAX_DRAWDOWN=0.1               # 10% maximum drawdown
STOP_LOSS_PCT=0.15             # 15% loss triggers position close
DAILY_LOSS_LIMIT=2000          # Stop trading if daily loss exceeds this

# ============= Strategy Parameters =============
PREDICTION_THRESHOLD=0.55      # Only trade if confidence > 55%
MIN_MARKET_LIQUIDITY=100       # Only trade markets with $100+ liquidity
MARKET_VOLUME_THRESHOLD=1000   # Consider market activity
EDGE_THRESHOLD=0.02            # Need 2% edge to trade

# ============= Scheduling =============
BOT_CHECK_INTERVAL=300         # Check for opportunities every 5 minutes
BOT_EXECUTION_TIME=09:00-17:00 # Only trade during market hours (optional)
PAPER_TRADING_MODE=true        # Simulate trades without real money

# ============= Monitoring & Logging =============
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/bot.log
ALERT_ON_LOSS=true
ALERT_THRESHOLD=500            # Alert if single trade loses > $500
ERROR_RECOVERY_ATTEMPTS=3
ERROR_RETRY_DELAY=30           # seconds

# ============= Database (optional) =============
SUPABASE_URL=https://...
SUPABASE_KEY=your_key_here

# ============= Frontend =============
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
